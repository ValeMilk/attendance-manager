# MongoDB Atlas Connection String
# Replace with your actual MongoDB URI from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/attendance-manager?retryWrites=true&w=majority

# JWT Secrets
JWT_SECRET=your_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_key_here_change_in_production

# Server Config
PORT=5000
NODE_ENV=development
